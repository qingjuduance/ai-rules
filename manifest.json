{
  "name": "ai-client-governance",
  "description": "Reusable agent-neutral governance plugin layer for AI coding clients, embedded as a complete Git repository.",
  "schema_version": 4,
  "distributionMode": "embedded-git-repository",
  "recommendedEmbed": {
    "targetPath": ".ai-client/ai-client-governance",
    "defaultMethod": "git-submodule",
    "preferredMethod": "git-submodule",
    "fallbackMethod": "nested-git-clone",
    "existingPreparedRepoMethod": "existing-embedded-git-repository"
  },
  "rulesLayout": {
    "rootEntryTarget": "AGENTS.md",
    "commonEntry": ".ai-client/ai-client-governance/AGENTS.md",
    "commonEntrySemantics": "canonical agent-neutral governance contract exposed through an adapter filename",
    "projectEntry": ".ai-client/project/rules/project/AGENTS.md",
    "adapterStrategy": "thin-native-entrypoints-import-or-point-to-common-and-project-facts"
  },
  "pathLayout": {
    "aiClientRoot": ".ai-client",
    "commonRepoName": "ai-client-governance",
    "commonRepoPath": "${aiClientRoot}/${commonRepoName}",
    "projectPath": "${aiClientRoot}/project",
    "placeholderPolicy": "Use placeholders in generated docs and command examples; use real relative Markdown links for clickable references."
  },
  "structuredRecords": {
    "store": ".ai-client/project/state/aicg.db",
    "engine": "sqlite",
    "schemaVersion": 1,
    "factSourcePriority": [
      "structured-sqlite-task-record",
      "tool-ledger-jsonl",
      "markdown-report-or-history"
    ],
    "commands": {
      "contractDescribe": "python .ai-client/ai-client-governance/scripts/ai_client_governance.py contract describe",
      "lifecycleInputFilter": "python .ai-client/ai-client-governance/scripts/ai_client_governance.py lifecycle input-filter --message <user-message> --task-id <task-id>",
      "lifecyclePreflight": "python .ai-client/ai-client-governance/scripts/ai_client_governance.py lifecycle preflight --task-id <task-id>",
      "taskRunPlan": "python .ai-client/ai-client-governance/scripts/ai_client_governance.py task-run plan --task-id <task-id> --event write-intent",
      "taskRunRun": "python .ai-client/ai-client-governance/scripts/ai_client_governance.py task-run run --task-id <task-id> --event write-intent",
      "taskRunDiagnose": "python .ai-client/ai-client-governance/scripts/ai_client_governance.py task-run diagnose --format json",
      "taskRecordInit": "python .ai-client/ai-client-governance/scripts/ai_client_governance.py task-record init",
      "taskRecordApply": "python .ai-client/ai-client-governance/scripts/ai_client_governance.py task-record apply --json <task-record.json>",
      "taskRecordGate": "python .ai-client/ai-client-governance/scripts/ai_client_governance.py task-record gate --task-id <task-id> --event preflight",
      "taskRecordStatus": "python .ai-client/ai-client-governance/scripts/ai_client_governance.py task-record status",
      "taskGateStructured": "python .ai-client/ai-client-governance/scripts/ai_client_governance.py task-gate --task-id <task-id>"
    },
    "mandatoryInputFilter": {
      "joinPoint": "user-message",
      "command": "python .ai-client/ai-client-governance/scripts/ai_client_governance.py lifecycle input-filter",
      "requiredEvent": "input-filter.preflight",
      "requiredTriggerTypes": [
        "user-message",
        "input-filter"
      ],
      "failPolicy": "fail_closed"
    },
    "mandatoryCommandCompression": {
      "joinPoint": "write-intent",
      "command": "python .ai-client/ai-client-governance/scripts/ai_client_governance.py task-run plan",
      "runnerCommand": "python .ai-client/ai-client-governance/scripts/ai_client_governance.py task-run run",
      "diagnoseCommand": "python .ai-client/ai-client-governance/scripts/ai_client_governance.py task-run diagnose",
      "requiredEvent": "command-compression.analysis",
      "appliesTo": [
        "medium-large-tasks",
        "mutating-tasks"
      ],
      "failPolicy": "fail_closed",
      "cachePolicy": "Cache is opt-in and limited to readonly/validation nodes; stateful, sequential, Git write, lock, task-record apply, git status, git diff, and git worktree list commands are no-cache.",
      "ledgerPolicy": "task-run run writes tool-invocations JSONL by default; use --no-ledger only for isolated tests. Prefer task-run run, gate-pool, or tool-invocations run for important shell commands; raw host shell calls must be justified when not automatically intercepted."
    },
    "markdownPolicy": "Markdown task tracking is a human-readable export or historical audit artifact, not a gate input for new tasks.",
    "readOnlyPolicy": "task-record status never creates the SQLite database; missing DB returns an empty summary."
  },
  "designPrinciples": [
    {
      "id": "governance-layer-not-runtime",
      "summary": "Govern host AI coding client capabilities without replacing the client, model, or agent runtime."
    },
    {
      "id": "complete-embedded-repository",
      "summary": "Keep common rules, scripts, skills, README, and manifest together as an embedded Git repository."
    },
    {
      "id": "entrypoints-are-adapters",
      "summary": "Treat AGENTS.md, CLAUDE.md, GEMINI.md, Copilot, Cursor, Cline, Windsurf, Continue, Roo, and Aider files as thin adapters to the same facts."
    },
    {
      "id": "deterministic-constraints-become-components",
      "summary": "Turn repeatable, checkable, or state-changing constraints into CLI commands, runtime components, gates, state files, or skills before expanding prose rules."
    },
    {
      "id": "compress-local-commands-before-model-roundtrips",
      "summary": "Analyze new local command candidates for dedupe, batching, gate-pool aggregation, ledger wrapping, or cache reuse before spending additional model turns."
    },
    {
      "id": "changes-need-isolation-and-evidence",
      "summary": "Require worktrees, task tracking, locks, tool ledgers, validation evidence, and final state reporting for modification tasks."
    },
    {
      "id": "project-specialization-stays-out-of-common",
      "summary": "Keep project business rules, resumes, learning paths, source snapshots, delivery details, and private preferences in the host project layer."
    },
    {
      "id": "preserve-native-project-assets",
      "summary": "Preserve existing native rule entries, skills, IDE configuration, and team conventions unless the user explicitly approves changes."
    },
    {
      "id": "sync-audits-do-not-decide",
      "summary": "Detect missing, dirty, ahead, behind, or diverged states without automatically pulling, pushing, merging, or deleting."
    },
    {
      "id": "live-state-over-snapshots",
      "summary": "Use task tracking, state files, and logs for recovery, but re-check live worktree, Git, session, lock, and queue state before final decisions."
    },
    {
      "id": "agent-neutral-portability",
      "summary": "Write common rules in agent-neutral terms and keep tool-specific behavior inside local adapters or skills."
    }
  ],
  "runtimeArchitecture": {
    "name": "ai-client-governance-plugin",
    "concept": "Spring-style governance plugin layer for AI coding clients. It assumes the host client provides conversation, tool execution, file writes, shell commands, approvals, and session recovery; AI Client Governance governs how those capabilities are used.",
    "hostClientAssumption": "Codex, Claude Code, Cursor, Cline, Windsurf, Continue, and similar clients already provide the agent runtime surface. AI Client Governance supplies policy, gates, evidence, and state audits on top of that surface.",
    "notAReplacementFor": [
      "host AI coding client",
      "agent runtime",
      "LangGraph workflow engine unless using a self-built runner"
    ],
    "coreContext": "AgentExecutionContext",
    "registryCommand": "python .ai-client/ai-client-governance/scripts/ai_client_governance.py runtime components",
    "componentKinds": [
      "input-filter",
      "processing-interceptor",
      "output-interceptor",
      "cross-cutting-gate",
      "reporter"
    ],
    "componentContract": [
      "id",
      "kind",
      "phase",
      "order",
      "fail_policy",
      "task_types",
      "task_sizes",
      "input_sources",
      "path_suffixes",
      "path_prefixes",
      "events",
      "condition",
      "requires_facts",
      "produces_facts",
      "effect",
      "gate_step",
      "dedupe_key",
      "performance_budget",
      "dependencies",
      "metadata"
    ],
    "failPolicies": [
      "fail_closed",
      "warn_only",
      "requires_approval",
      "report_only"
    ],
    "extensionPolicy": "Add deterministic behavior as registered governance components before expanding prose rules.",
    "designReferences": {
      "springAop": "https://docs.spring.io/spring-framework/reference/core/aop/introduction-defn.html",
      "bazelRemoteCache": "https://bazel.build/remote/cache-remote",
      "gradleBuildCache": "https://docs.gradle.org/current/userguide/build_cache.html",
      "openTelemetryTraces": "https://opentelemetry.io/docs/concepts/signals/traces/"
    },
    "documentImpactPolicy": {
      "phase": "post-change",
      "trigger": "rules, scripts, skills, manifest, README, adapters, or Markdown changes that may affect user-facing docs or references",
      "gateStep": "doc-index",
      "trackingEvidence": "record affected docs and references, updated files, or explicit no-impact rationale in the structured task record"
    },
    "executionGuarantees": {
      "componentVisibility": "python .ai-client/ai-client-governance/scripts/ai_client_governance.py runtime components must show matching nodes for the task context",
      "gateExecution": "python .ai-client/ai-client-governance/scripts/ai_client_governance.py gate-pool --dry-run must show gate steps without mutating state; actual runs require a task id or historical tracking source",
      "dedupePolicy": "gate-pool de-duplicates by gate_step and aggregates changed paths before running the same gate",
      "performancePolicy": "avoid unconditional checks; every expensive node needs event, task type, path, final-only, or changed-path triggers",
      "worktreeCreationPolicy": "plan-output/write-intent/resume must expose worktree-creation-policy, requiring worktree-task create by default plus sparse/source snapshot handling evidence; raw git worktree add is break-glass only",
      "worktreeLiveStatePolicy": "worktree-task reconcile treats Git worktree list as the source of truth and blocks active coord sessions whose worktree disappeared",
      "inputFilterPreflightPolicy": "user-message must pass lifecycle input-filter and task-record gate --event preflight before later processing; missing input-filter.preflight facts fail closed",
      "commandCompressionPolicy": "medium, large, or mutating tasks must record command-compression.analysis before write-intent or final gates; task-run plan provides the local dedupe and grouping event payload",
      "taskRunExecutionPolicy": "task-run run executes one compressed local DAG, parallelizes only readonly/validation groups, writes ledger events by default, and stores trace JSON when requested",
      "taskRunCachePolicy": "task-run cache keys include runner version, command, cwd, node kind, task types, changed paths, declared input hashes, and Git HEAD; cache hits still write ledger events",
      "taskRunDiagnosticsPolicy": "task-run diagnose reports terminal duplicate commands, ledger failures, cache hit/miss counts, coord locks/sessions, missing worktrees, and raw shell interception gaps",
      "structuredRecordPolicy": "new tasks should call contract describe before execution and write typed SQLite task records before preflight/final gates; task-id mode does not require Markdown task tracking",
      "hostSubmoduleCloseoutPolicy": "after merging an embedded ai-client-governance worktree, host closeout must verify and commit the .ai-client/ai-client-governance gitlink, worktrees.json, and related task tracking",
      "completionTestPolicy": "completion-test plans required validation from changed paths, task types, and acceptance criteria",
      "outputBoundaryPolicy": "Git push state is audited at plan-output, status-output, and final-output boundaries; no automatic push"
    },
    "eventBoundaries": [
      "user-message",
      "plan-output",
      "status-output",
      "write-intent",
      "after-change",
      "completion-test",
      "final-output",
      "resume",
      "merge-cleanup",
      "session-start",
      "state-audit"
    ],
    "runtimeCommands": {
      "components": "python .ai-client/ai-client-governance/scripts/ai_client_governance.py runtime components",
      "contractDescribe": "python .ai-client/ai-client-governance/scripts/ai_client_governance.py contract describe",
      "taskRunPlan": "python .ai-client/ai-client-governance/scripts/ai_client_governance.py task-run plan",
      "taskRunRun": "python .ai-client/ai-client-governance/scripts/ai_client_governance.py task-run run",
      "taskRunDiagnose": "python .ai-client/ai-client-governance/scripts/ai_client_governance.py task-run diagnose",
      "lifecycleInputFilter": "python .ai-client/ai-client-governance/scripts/ai_client_governance.py lifecycle input-filter",
      "lifecyclePreflight": "python .ai-client/ai-client-governance/scripts/ai_client_governance.py lifecycle preflight --task-id <task-id>",
      "taskRecord": "python .ai-client/ai-client-governance/scripts/ai_client_governance.py task-record",
      "gatePool": "python .ai-client/ai-client-governance/scripts/ai_client_governance.py gate-pool",
      "completionTest": "python .ai-client/ai-client-governance/scripts/ai_client_governance.py completion-test",
      "worktreeReconcile": "python .ai-client/ai-client-governance/scripts/ai_client_governance.py worktree-task reconcile --strict",
      "worktreeCloseoutAll": "python .ai-client/ai-client-governance/scripts/ai_client_governance.py worktree-task closeout-all --plan",
      "hostCloseout": "python .ai-client/ai-client-governance/scripts/ai_client_governance.py worktree-task host-closeout --repo ai-client-governance --require-task-tracking --require-clean-host"
    }
  },
  "agentEntryAdapters": [
    {
      "tool": "codex-agents-ecosystem",
      "paths": [
