{
  "name": "ai-rules",
  "description": "Reusable common Codex/AI collaboration rules.",
  "schema_version": 2,
  "rules_layout": {
    "root_entry_target": "AGENTS.md",
    "common_rules_source": "AGENTS.md",
    "common_rules_target": ".codex/rules/common/AGENTS.md",
    "project_rules_target": ".codex/rules/project/AGENTS.md",
    "project_rules_policy": "create_placeholder_only"
  },
  "managed_paths": [
    {
      "source": "AGENTS.md",
      "target": ".codex/rules/common/AGENTS.md",
      "type": "file"
    },
    {
      "source": ".codex/skills/agents-rule-maintainer",
      "target": ".codex/skills/agents-rule-maintainer",
      "type": "directory"
    },
    {
      "source": ".codex/skills/self-correction-planner",
      "target": ".codex/skills/self-correction-planner",
      "type": "directory"
    },
    {
      "source": "scripts/agent_comm.py",
      "target": "scripts/agent_comm.py",
      "type": "file"
    },
    {
      "source": "scripts/agent_group_status.py",
      "target": "scripts/agent_group_status.py",
      "type": "file"
    },
    {
      "source": "scripts/scan_corrections.py",
      "target": "scripts/scan_corrections.py",
      "type": "file"
    },
    {
      "source": "check-ai-rules-sync.ps1",
      "target": "check-ai-rules-sync.ps1",
      "type": "file"
    }
  ],
  "generated_paths": [
    "AGENTS.md"
  ],
  "preserved_paths": [
    ".codex/rules/project/",
    ".codex/task-tracking/",
    ".codex/pending-tasks/",
    ".codex/agent-comm/",
    ".codex/agent-groups/"
  ],
  "sync_policy": {
    "trigger": "new_session_start",
    "interval_hours": 24,
    "remote": "origin",
    "merge_strategy": "git_pull_no_rebase",
    "conflict_policy": "stop_and_report"
  },
  "install": {
    "config_path": ".codex/ai-rules-config.json",
    "backup_dir": ".codex/ai-rules-backups",
    "auto_refresh_default": true
  }
}
