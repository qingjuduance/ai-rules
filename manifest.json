      "overwritePolicy": "preserve-existing; rewrite-only-with-ForceAgentAdapters"
    }
  ],
  "syncPolicy": {
    "checkEverySession": true,
    "fetchIntervalHours": 24,
    "warnUntilSynced": true,
    "autoFetch": true,
    "autoPull": false,
    "autoPush": false,
    "remote": "origin",
    "dirtyPolicy": "warn-every-session",
    "behindPolicy": "warn-and-require-manual-pull",
    "aheadPolicy": "warn-and-require-manual-push",
    "divergedPolicy": "warn-and-require-manual-resolution",
    "missingEmbeddedRepoPolicy": "embed-before-rule-work"
  },
  "writeback": {
    "method": "git-commands-inside-embedded-repo",
    "workingDirectory": ".ai-client/ai-client-governance",
    "requireUserApprovalForPush": true,
    "forbiddenSources": [
      ".ai-client/project/rules/project/",
      ".ai-client/project/skills/",
      ".ai-client/project/records/task-tracking/",
      ".ai-client/project/records/pending-tasks/",
      ".ai-client/project/records/corrections/",
      ".ai-client/project/logs/tool-invocations/",
      ".ai-client/project/records/project-status/",
      "project-specific-documents"
    ]
  },
  "targetProjectOwnership": {
    "priorityOrder": [
      "native-project-assets",
      "project-specialization",
      "ai-client-governance-common"
    ],
    "rootAgents": "native-project-owned",
    "nativeRuleAdapters": "native-project-owned",
    "nativeProjectSkills": "native-project-owned",
    "projectRules": "project-specialization-owned",
    "projectSkills": "project-specialization-owned",
    "commonRules": "ai-client-governance-owned",
    "commonSkills": "ai-client-governance-owned",
    "existingProjectContentPolicy": "preserve-and-report",
    "skillConflictPolicy": "prefer-native-then-project-then-ai-client-governance-and-report-duplicate",
    "nativeProjectContentWritePolicy": "read-index-report-only-unless-user-explicitly-approves"
  },
  "repoContents": {
    "commonRules": "AGENTS.md",
    "commonRulesSemantics": "agent-neutral governance contract exposed through the AGENTS.md adapter",
    "pythonPackage": "src/ai_client_governance",
    "runtime": "src/ai_client_governance/runtime",
    "skills": [
      "skills/agents-rule-maintainer",
      "skills/codex-token-usage",
      "skills/self-correction-planner"
    ],
    "scripts": [
      "scripts/ai_client_governance.py",
      "check-ai-client-governance-sync.ps1",
      "install-ai-client-governance.ps1"
    ]
  },
  "targetProjectDefaultGeneratedFiles": [
    "AGENTS.md",
    ".ai-client/ai-client-governance-config.json",
    ".ai-client/project/rules/project/AGENTS.md"
  ],
  "targetProjectOptionalGeneratedFiles": [
    "CLAUDE.md",
    "GEMINI.md",
    "CONVENTIONS.md",
    ".github/copilot-instructions.md",
    ".github/instructions/ai-client-governance.instructions.md",
    ".cursor/rules/ai-client-governance.mdc",
    ".clinerules/ai-client-governance.md",
    ".windsurf/rules/ai-client-governance.md",
    ".continue/rules/ai-client-governance.md",
    ".roo/rules/ai-client-governance.md"
  ],
  "installer": {
    "script": "install-ai-client-governance.ps1",
    "defaultMode": "git-submodule",
    "fallbackMode": "nested-git-clone",
    "existingPreparedRepoMode": "existing-embedded-git-repository",
    "supportsPlanOnly": true,
    "supportsPowerShellWhatIf": true,
    "infersSourceUrlFromOrigin": true,
    "infersBranchFromRulesRepo": true,
    "supportsLocalPathSubmoduleSource": true,
    "supportsRelativeLocalPathSubmoduleSource": true,
    "existingFilesPolicy": {
      "rootAgents": "create-only-when-missing; rewrite-only-with-ForceRootEntry",
      "agentAdapters": "not-generated-by-default; create-missing-with-InstallAgentAdapters; rewrite-only-with-ForceAgentAdapters",
      "config": "backup-then-rewrite",
      "projectRules": "create-only-when-missing",
      "nativeProjectSkills": "preserve-existing; never-modify-without-explicit-user-approval",
      "projectSkills": "create-or-update-project-specializations-only; never-install-common-skills-into-project",
      "existingRegisteredSubmodule": "keep-and-continue",
      "existingUnregisteredGitRepo": "stop-unless-AdoptExistingGitRepo",
      "existingPreparedEmbeddedRepo": "use-with-Mode-existing; do-not-clone-or-submodule-add",
      "existingNonGitEmbedPath": "stop-and-require-manual-review"
    },
    "postInstallSyncCheck": {
      "default": true,
      "command": ".ai-client/ai-client-governance/check-ai-client-governance-sync.ps1 -NoFetch",
      "skipParameter": "SkipSyncCheck"
    },
    "gitBoundary": {
      "autoCommit": false,
      "autoPush": false,
      "requiresHumanReview": true
    }
  },
  "targetProjectPreservedPaths": [
