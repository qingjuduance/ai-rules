  "oldLayoutPolicy": "The previous .codex governance layout is not supported. Do not generate adapters, state, records, tools, skills, or fallbacks there; if active docs or scripts reference it, replace them with .ai-client paths. Historical audit records may mention old paths only as past facts.",
  "adapterPolicy": {
    "defaultGeneratedAdapters": [
      "AGENTS.md"
    ],
    "defaultGenerateMissingAdapters": false,
    "installParameter": "InstallAgentAdapters",
    "forceParameter": "ForceAgentAdapters",
    "existingAdapterPolicy": "not-generated-by-default; preserve-existing-when-installing; rewrite-only-with-ForceAgentAdapters",
    "adapterContentPolicy": "thin-read-order-sync-boundary-only",
    "canonicalFacts": [
      ".ai-client/ai-client-governance/AGENTS.md",
      ".ai-client/project/rules/project/AGENTS.md"
    ],
    "priorityOrder": [
      "native-project-assets",
      "project-specialization",
      "ai-client-governance-common"
    ]
  },
  "githubReadmeGate": {
    "beforePush": true,
    "requireCurrentAdvantages": true,
    "sourceOfTruth": [
      "README.md",
      "manifest.json",
      "AGENTS.md"
    ]
  }
}
