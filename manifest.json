{
  "name": "ai-rules",
  "description": "Reusable agent-neutral governance plugin layer for AI coding clients, embedded as a complete Git repository.",
  "schema_version": 3,
  "distributionMode": "embedded-git-repository",
  "recommendedEmbed": {
    "targetPath": ".codex/ai-rules",
    "defaultMethod": "git-submodule",
    "preferredMethod": "git-submodule",
    "fallbackMethod": "nested-git-clone"
  },
  "rulesLayout": {
    "rootEntryTarget": "AGENTS.md",
    "commonEntry": ".codex/ai-rules/AGENTS.md",
    "commonEntrySemantics": "canonical agent-neutral governance contract; AGENTS.md is a compatibility filename",
    "projectEntry": ".codex/project/rules/project/AGENTS.md",
    "adapterStrategy": "thin-native-entrypoints-import-or-point-to-common-and-project-facts"
  },
  "runtimeArchitecture": {
    "name": "ai-rules-client-governance-plugin",
    "concept": "Spring-style governance plugin layer for AI coding clients. It assumes the host client provides conversation, tool execution, file writes, shell commands, approvals, and session recovery; ai-rules governs how those capabilities are used.",
    "hostClientAssumption": "Codex, Claude Code, Cursor, Cline, Windsurf, Continue, and similar clients already provide the agent runtime surface. ai-rules supplies policy, gates, evidence, and state audits on top of that surface.",
    "notAReplacementFor": [
      "host AI coding client",
      "agent runtime",
      "LangGraph workflow engine unless using a self-built runner"
    ],
    "coreContext": "AgentExecutionContext",
    "registryCommand": "python .codex/ai-rules/scripts/ai_rules.py runtime components",
    "componentKinds": [
      "input-filter",
      "processing-interceptor",
      "output-interceptor",
      "cross-cutting-gate",
      "reporter"
    ],
    "componentContract": [
      "id",
      "kind",
      "phase",
      "order",
      "fail_policy",
      "task_types",
      "task_sizes",
      "input_sources",
      "path_suffixes",
      "path_prefixes",
      "events",
      "condition",
      "requires_facts",
      "produces_facts",
      "effect",
      "gate_step",
      "dedupe_key",
      "performance_budget",
      "dependencies",
      "metadata"
    ],
    "failPolicies": [
      "fail_closed",
      "warn_only",
      "requires_approval",
      "report_only"
    ],
    "extensionPolicy": "Add deterministic behavior as registered governance components before expanding prose rules.",
    "documentImpactPolicy": {
      "phase": "post-change",
      "trigger": "rules, scripts, skills, manifest, README, adapters, or Markdown changes that may affect user-facing docs or references",
      "gateStep": "doc-index",
      "trackingEvidence": "record affected docs and references, updated files, or explicit no-impact rationale"
    },
    "executionGuarantees": {
      "componentVisibility": "python .codex/ai-rules/scripts/ai_rules.py runtime components must show matching nodes for the task context",
      "gateExecution": "python .codex/ai-rules/scripts/ai_rules.py gate-pool --dry-run must show executable gate steps before final runs",
      "dedupePolicy": "gate-pool de-duplicates by gate_step and aggregates changed paths before running the same gate",
      "performancePolicy": "avoid unconditional checks; every expensive node needs event, task type, path, final-only, or changed-path triggers",
      "worktreeLiveStatePolicy": "worktree-task reconcile treats Git worktree list as the source of truth and blocks active coord sessions whose worktree disappeared",
      "hostSubmoduleCloseoutPolicy": "after merging an embedded ai-rules worktree, host closeout must verify and commit the .codex/ai-rules gitlink, worktrees.json, and related task tracking",
      "completionTestPolicy": "completion-test plans required validation from changed paths, task types, and acceptance criteria",
      "outputBoundaryPolicy": "Git push state is audited at plan-output, status-output, and final-output boundaries; no automatic push"
    },
    "eventBoundaries": [
      "user-message",
      "plan-output",
      "status-output",
      "write-intent",
      "after-change",
      "completion-test",
      "final-output",
      "resume",
      "merge-cleanup",
      "session-start",
      "state-audit"
    ],
    "runtimeCommands": {
      "components": "python .codex/ai-rules/scripts/ai_rules.py runtime components",
      "gatePool": "python .codex/ai-rules/scripts/ai_rules.py gate-pool",
      "completionTest": "python .codex/ai-rules/scripts/ai_rules.py completion-test",
      "worktreeReconcile": "python .codex/ai-rules/scripts/ai_rules.py worktree-task reconcile --strict",
      "hostCloseout": "python .codex/ai-rules/scripts/ai_rules.py worktree-task host-closeout --repo ai-rules --require-task-tracking --require-clean-host"
    }
  },
  "agentEntryAdapters": [
    {
      "tool": "codex-agents-ecosystem",
      "paths": [
        "AGENTS.md"
      ],
      "defaultGenerated": true,
      "overwritePolicy": "preserve-existing; rewrite-only-with-ForceRootEntry"
    },
    {
      "tool": "claude-code",
      "paths": [
        "CLAUDE.md"
      ],
      "defaultGenerated": true,
      "overwritePolicy": "preserve-existing; rewrite-only-with-ForceAgentAdapters"
    },
    {
      "tool": "gemini-cli",
      "paths": [
        "GEMINI.md"
      ],
      "defaultGenerated": true,
      "overwritePolicy": "preserve-existing; rewrite-only-with-ForceAgentAdapters"
    },
    {
      "tool": "github-copilot",
      "paths": [
        ".github/copilot-instructions.md",
        ".github/instructions/ai-rules.instructions.md"
      ],
      "defaultGenerated": true,
      "overwritePolicy": "preserve-existing; rewrite-only-with-ForceAgentAdapters"
    },
    {
      "tool": "cursor",
      "paths": [
        ".cursor/rules/ai-rules.mdc"
      ],
      "defaultGenerated": true,
      "overwritePolicy": "preserve-existing; rewrite-only-with-ForceAgentAdapters"
    },
    {
      "tool": "cline",
      "paths": [
        ".clinerules/ai-rules.md"
      ],
      "defaultGenerated": true,
      "overwritePolicy": "preserve-existing; rewrite-only-with-ForceAgentAdapters"
    },
    {
      "tool": "windsurf",
      "paths": [
        ".windsurf/rules/ai-rules.md"
      ],
      "defaultGenerated": true,
      "overwritePolicy": "preserve-existing; rewrite-only-with-ForceAgentAdapters"
    },
    {
      "tool": "continue",
      "paths": [
        ".continue/rules/ai-rules.md"
      ],
      "defaultGenerated": true,
      "overwritePolicy": "preserve-existing; rewrite-only-with-ForceAgentAdapters"
    },
    {
      "tool": "roo-code",
      "paths": [
        ".roo/rules/ai-rules.md"
      ],
      "defaultGenerated": true,
      "overwritePolicy": "preserve-existing; rewrite-only-with-ForceAgentAdapters"
    },
    {
      "tool": "aider",
      "paths": [
        "CONVENTIONS.md"
      ],
      "defaultGenerated": true,
      "overwritePolicy": "preserve-existing; rewrite-only-with-ForceAgentAdapters"
    }
  ],
  "syncPolicy": {
    "checkEverySession": true,
    "fetchIntervalHours": 24,
    "warnUntilSynced": true,
    "autoFetch": true,
    "autoPull": false,
    "autoPush": false,
    "remote": "origin",
    "dirtyPolicy": "warn-every-session",
    "behindPolicy": "warn-and-require-manual-pull",
    "aheadPolicy": "warn-and-require-manual-push",
    "divergedPolicy": "warn-and-require-manual-resolution",
    "missingEmbeddedRepoPolicy": "embed-before-rule-work"
  },
  "writeback": {
    "method": "git-commands-inside-embedded-repo",
    "workingDirectory": ".codex/ai-rules",
    "requireUserApprovalForPush": true,
    "forbiddenSources": [
      ".codex/project/rules/project/",
      ".codex/project/skills/",
      ".codex/project/records/task-tracking/",
      ".codex/project/records/pending-tasks/",
      ".codex/project/records/corrections/",
      ".codex/project/logs/tool-invocations/",
      ".codex/project/records/project-status/",
      "project-specific-documents"
    ]
  },
  "targetProjectOwnership": {
    "priorityOrder": [
      "native-project-assets",
      "project-specialization",
      "ai-rules-common"
    ],
    "rootAgents": "native-project-owned",
    "nativeRuleAdapters": "native-project-owned",
    "nativeProjectSkills": "native-project-owned",
    "projectRules": "project-specialization-owned",
    "projectSkills": "project-specialization-owned",
    "commonRules": "ai-rules-owned",
    "commonSkills": "ai-rules-owned",
    "existingProjectContentPolicy": "preserve-and-report",
    "skillConflictPolicy": "prefer-native-then-project-then-ai-rules-and-report-duplicate",
    "nativeProjectContentWritePolicy": "read-index-report-only-unless-user-explicitly-approves"
  },
  "repoContents": {
    "commonRules": "AGENTS.md",
    "commonRulesSemantics": "agent-neutral governance contract exposed through AGENTS.md compatibility adapter",
    "pythonPackage": "src/ai_rules",
    "runtime": "src/ai_rules/runtime",
    "skills": [
      ".codex/skills/agents-rule-maintainer",
      ".codex/skills/codex-token-usage",
      ".codex/skills/self-correction-planner"
    ],
    "scripts": [
      "scripts/ai_rules.py",
      "check-ai-rules-sync.ps1",
      "install-ai-rules.ps1"
    ]
  },
  "targetProjectGeneratedFiles": [
    "AGENTS.md",
    "CLAUDE.md",
    "GEMINI.md",
    "CONVENTIONS.md",
    ".github/copilot-instructions.md",
    ".github/instructions/ai-rules.instructions.md",
    ".cursor/rules/ai-rules.mdc",
    ".clinerules/ai-rules.md",
    ".windsurf/rules/ai-rules.md",
    ".continue/rules/ai-rules.md",
    ".roo/rules/ai-rules.md",
    ".codex/ai-rules-config.json",
    ".codex/project/rules/project/AGENTS.md"
  ],
  "installer": {
    "script": "install-ai-rules.ps1",
    "defaultMode": "git-submodule",
    "fallbackMode": "nested-git-clone",
    "supportsPlanOnly": true,
    "supportsPowerShellWhatIf": true,
    "infersSourceUrlFromOrigin": true,
    "infersBranchFromRulesRepo": true,
    "supportsLocalPathSubmoduleSource": true,
    "supportsRelativeLocalPathSubmoduleSource": true,
    "existingFilesPolicy": {
      "rootAgents": "create-only-when-missing; rewrite-only-with-ForceRootEntry",
      "agentAdapters": "create-only-when-missing; rewrite-only-with-ForceAgentAdapters; skip-with-SkipAgentAdapters",
      "config": "backup-then-rewrite",
      "projectRules": "create-only-when-missing",
      "nativeProjectSkills": "preserve-existing; never-modify-without-explicit-user-approval",
      "projectSkills": "create-or-update-project-specializations-only; never-install-common-skills-into-project",
      "existingRegisteredSubmodule": "keep-and-continue",
      "existingUnregisteredGitRepo": "stop-unless-AdoptExistingGitRepo",
      "existingNonGitEmbedPath": "stop-and-require-manual-review"
    },
    "postInstallSyncCheck": {
      "default": true,
      "command": ".codex/ai-rules/check-ai-rules-sync.ps1 -NoFetch",
      "skipParameter": "SkipSyncCheck"
    },
    "gitBoundary": {
      "autoCommit": false,
      "autoPush": false,
      "requiresHumanReview": true
    }
  },
  "targetProjectPreservedPaths": [
    "AGENTS.md",
    "CLAUDE.md",
    "GEMINI.md",
    "CONVENTIONS.md",
    ".github/copilot-instructions.md",
    ".github/instructions/",
    ".cursor/rules/",
    ".clinerules/",
    ".windsurf/rules/",
    ".continue/rules/",
    ".roo/rules/",
    ".codex/project/rules/project/",
    ".codex/project/skills/",
    ".codex/project/records/task-tracking/",
    ".codex/project/records/pending-tasks/",
    ".codex/project/records/corrections/",
    ".codex/project/records/project-status/",
    ".codex/project/agents/",
    ".codex/project/logs/",
    ".codex/project/state/",
    ".codex/project/tools/",
    ".codex/project/cache/",
    ".codex/project/tmp/"
  ],
  "targetProjectLegacyPathsDoNotGenerate": [
    ".codex/rules/",
    ".codex/skills/",
    ".codex/task-tracking/",
    ".codex/pending-tasks/",
    ".codex/corrections/",
    ".codex/agent-comm/",
    ".codex/agent-groups/",
    ".codex/tool-invocations/",
    ".codex/project-status/"
  ],
  "legacyPathPolicy": "do-not-generate; report-and-migrate-forward-when-in-current-scope",
  "adapterPolicy": {
    "defaultGenerateMissingAdapters": true,
    "skipParameter": "SkipAgentAdapters",
    "forceParameter": "ForceAgentAdapters",
    "existingAdapterPolicy": "preserve-and-report",
    "adapterContentPolicy": "thin-read-order-sync-boundary-only",
    "canonicalFacts": [
      ".codex/ai-rules/AGENTS.md",
      ".codex/project/rules/project/AGENTS.md"
    ],
    "priorityOrder": [
      "native-project-assets",
      "project-specialization",
      "ai-rules-common"
    ]
  },
  "githubReadmeGate": {
    "beforePush": true,
    "requireCurrentAdvantages": true,
    "sourceOfTruth": [
      "README.md",
      "manifest.json",
      "AGENTS.md"
    ]
  }
}
