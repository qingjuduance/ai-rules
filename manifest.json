{
  "name": "ai-rules",
  "description": "Reusable agent-neutral AI execution workflow framework embedded as a complete Git repository.",
  "schema_version": 3,
  "distributionMode": "embedded-git-repository",
  "recommendedEmbed": {
    "targetPath": ".codex/ai-rules",
    "defaultMethod": "git-submodule",
    "preferredMethod": "git-submodule",
    "fallbackMethod": "nested-git-clone"
  },
  "rulesLayout": {
    "rootEntryTarget": "AGENTS.md",
    "commonEntry": ".codex/ai-rules/AGENTS.md",
    "commonEntrySemantics": "canonical agent-neutral workflow source; AGENTS.md is a compatibility filename",
    "projectEntry": ".codex/project/rules/project/AGENTS.md",
    "adapterStrategy": "thin-native-entrypoints-import-or-point-to-common-and-project-facts"
  },
  "agentEntryAdapters": [
    {
      "tool": "codex-agents-ecosystem",
      "paths": [
        "AGENTS.md"
      ],
      "defaultGenerated": true,
      "overwritePolicy": "preserve-existing; rewrite-only-with-ForceRootEntry"
    },
    {
      "tool": "claude-code",
      "paths": [
        "CLAUDE.md"
      ],
      "defaultGenerated": true,
      "overwritePolicy": "preserve-existing; rewrite-only-with-ForceAgentAdapters"
    },
    {
      "tool": "gemini-cli",
      "paths": [
        "GEMINI.md"
      ],
      "defaultGenerated": true,
      "overwritePolicy": "preserve-existing; rewrite-only-with-ForceAgentAdapters"
    },
    {
      "tool": "github-copilot",
      "paths": [
        ".github/copilot-instructions.md",
        ".github/instructions/ai-rules.instructions.md"
      ],
      "defaultGenerated": true,
      "overwritePolicy": "preserve-existing; rewrite-only-with-ForceAgentAdapters"
    },
    {
      "tool": "cursor",
      "paths": [
        ".cursor/rules/ai-rules.mdc"
      ],
      "defaultGenerated": true,
      "overwritePolicy": "preserve-existing; rewrite-only-with-ForceAgentAdapters"
    },
    {
      "tool": "cline",
      "paths": [
        ".clinerules/ai-rules.md"
      ],
      "defaultGenerated": true,
      "overwritePolicy": "preserve-existing; rewrite-only-with-ForceAgentAdapters"
    },
    {
      "tool": "windsurf",
      "paths": [
        ".windsurf/rules/ai-rules.md"
      ],
      "defaultGenerated": true,
      "overwritePolicy": "preserve-existing; rewrite-only-with-ForceAgentAdapters"
    },
    {
      "tool": "continue",
      "paths": [
        ".continue/rules/ai-rules.md"
      ],
      "defaultGenerated": true,
      "overwritePolicy": "preserve-existing; rewrite-only-with-ForceAgentAdapters"
    },
    {
      "tool": "roo-code",
      "paths": [
        ".roo/rules/ai-rules.md"
      ],
      "defaultGenerated": true,
      "overwritePolicy": "preserve-existing; rewrite-only-with-ForceAgentAdapters"
    },
    {
      "tool": "aider",
      "paths": [
        "CONVENTIONS.md"
      ],
      "defaultGenerated": true,
      "overwritePolicy": "preserve-existing; rewrite-only-with-ForceAgentAdapters"
    }
  ],
  "syncPolicy": {
    "checkEverySession": true,
    "fetchIntervalHours": 24,
    "warnUntilSynced": true,
    "autoFetch": true,
    "autoPull": false,
    "autoPush": false,
    "remote": "origin",
    "dirtyPolicy": "warn-every-session",
    "behindPolicy": "warn-and-require-manual-pull",
    "aheadPolicy": "warn-and-require-manual-push",
    "divergedPolicy": "warn-and-require-manual-resolution",
    "missingEmbeddedRepoPolicy": "embed-before-rule-work"
  },
  "writeback": {
    "method": "git-commands-inside-embedded-repo",
    "workingDirectory": ".codex/ai-rules",
    "requireUserApprovalForPush": true,
    "forbiddenSources": [
      ".codex/project/rules/project/",
      ".codex/project/skills/",
      ".codex/project/records/task-tracking/",
      ".codex/project/records/pending-tasks/",
      ".codex/project/records/corrections/",
      ".codex/project/logs/tool-invocations/",
      ".codex/project/records/project-status/",
      "project-specific-documents"
    ]
  },
  "targetProjectOwnership": {
    "priorityOrder": [
      "native-project-assets",
      "project-specialization",
      "ai-rules-common"
    ],
    "rootAgents": "native-project-owned",
    "nativeRuleAdapters": "native-project-owned",
    "nativeProjectSkills": "native-project-owned",
    "projectRules": "project-specialization-owned",
    "projectSkills": "project-specialization-owned",
    "commonRules": "ai-rules-owned",
    "commonSkills": "ai-rules-owned",
    "existingProjectContentPolicy": "preserve-and-report",
    "skillConflictPolicy": "prefer-native-then-project-then-ai-rules-and-report-duplicate",
    "nativeProjectContentWritePolicy": "read-index-report-only-unless-user-explicitly-approves"
  },
  "repoContents": {
    "commonRules": "AGENTS.md",
    "commonRulesSemantics": "agent-neutral workflow source exposed through AGENTS.md compatibility adapter",
    "pythonPackage": "src/ai_rules",
    "skills": [
      ".codex/skills/agents-rule-maintainer",
      ".codex/skills/codex-token-usage",
      ".codex/skills/self-correction-planner"
    ],
    "scripts": [
      "scripts/ai_rules.py",
      "check-ai-rules-sync.ps1",
      "install-ai-rules.ps1"
    ]
  },
  "targetProjectGeneratedFiles": [
    "AGENTS.md",
    "CLAUDE.md",
    "GEMINI.md",
    "CONVENTIONS.md",
    ".github/copilot-instructions.md",
    ".github/instructions/ai-rules.instructions.md",
    ".cursor/rules/ai-rules.mdc",
    ".clinerules/ai-rules.md",
    ".windsurf/rules/ai-rules.md",
    ".continue/rules/ai-rules.md",
    ".roo/rules/ai-rules.md",
    ".codex/ai-rules-config.json",
    ".codex/project/rules/project/AGENTS.md"
  ],
  "installer": {
    "script": "install-ai-rules.ps1",
    "defaultMode": "git-submodule",
    "fallbackMode": "nested-git-clone",
    "supportsPlanOnly": true,
    "supportsPowerShellWhatIf": true,
    "infersSourceUrlFromOrigin": true,
    "infersBranchFromRulesRepo": true,
    "supportsLocalPathSubmoduleSource": true,
    "supportsRelativeLocalPathSubmoduleSource": true,
    "existingFilesPolicy": {
      "rootAgents": "create-only-when-missing; rewrite-only-with-ForceRootEntry",
      "agentAdapters": "create-only-when-missing; rewrite-only-with-ForceAgentAdapters; skip-with-SkipAgentAdapters",
      "config": "backup-then-rewrite",
      "projectRules": "create-only-when-missing",
      "nativeProjectSkills": "preserve-existing; never-modify-without-explicit-user-approval",
      "projectSkills": "create-or-update-project-specializations-only; never-install-common-skills-into-project",
      "existingRegisteredSubmodule": "keep-and-continue",
      "existingUnregisteredGitRepo": "stop-unless-AdoptExistingGitRepo",
      "existingNonGitEmbedPath": "stop-and-require-manual-review"
    },
    "postInstallSyncCheck": {
      "default": true,
      "command": ".codex/ai-rules/check-ai-rules-sync.ps1 -NoFetch",
      "skipParameter": "SkipSyncCheck"
    },
    "gitBoundary": {
      "autoCommit": false,
      "autoPush": false,
      "requiresHumanReview": true
    }
  },
  "targetProjectPreservedPaths": [
    "AGENTS.md",
    "CLAUDE.md",
    "GEMINI.md",
    "CONVENTIONS.md",
    ".github/copilot-instructions.md",
    ".github/instructions/",
    ".cursor/rules/",
    ".clinerules/",
    ".windsurf/rules/",
    ".continue/rules/",
    ".roo/rules/",
    ".codex/project/rules/project/",
    ".codex/project/skills/",
    ".codex/project/records/task-tracking/",
    ".codex/project/records/pending-tasks/",
    ".codex/project/records/corrections/",
    ".codex/project/records/project-status/",
    ".codex/project/agents/",
    ".codex/project/logs/",
    ".codex/project/state/",
    ".codex/project/tools/",
    ".codex/project/cache/",
    ".codex/project/tmp/"
  ],
  "targetProjectLegacyPathsDoNotGenerate": [
    ".codex/rules/",
    ".codex/skills/",
    ".codex/task-tracking/",
    ".codex/pending-tasks/",
    ".codex/corrections/",
    ".codex/agent-comm/",
    ".codex/agent-groups/",
    ".codex/tool-invocations/",
    ".codex/project-status/"
  ],
  "legacyPathPolicy": "do-not-generate; report-and-migrate-forward-when-in-current-scope",
  "adapterPolicy": {
    "defaultGenerateMissingAdapters": true,
    "skipParameter": "SkipAgentAdapters",
    "forceParameter": "ForceAgentAdapters",
    "existingAdapterPolicy": "preserve-and-report",
    "adapterContentPolicy": "thin-read-order-sync-boundary-only",
    "canonicalFacts": [
      ".codex/ai-rules/AGENTS.md",
      ".codex/project/rules/project/AGENTS.md"
    ],
    "priorityOrder": [
      "native-project-assets",
      "project-specialization",
      "ai-rules-common"
    ]
  },
  "githubReadmeGate": {
    "beforePush": true,
    "requireCurrentAdvantages": true,
    "sourceOfTruth": [
      "README.md",
      "manifest.json",
      "AGENTS.md"
    ]
  }
}
